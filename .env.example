GENAI_API_KEY=your_gemini_api_key_here
GCP_PROJECT_ID=alan-live-tutor

# Local development: gcloud CLI impersonation for Firestore access
# Your gcloud account (must have serviceAccountTokenCreator on the SA below)
GCP_LOCAL_ACCOUNT=your-email@gmail.com
# Service account to impersonate (has Firestore access)
GCP_SERVICE_ACCOUNT=github-deploy@alan-live-tutor.iam.gserviceaccount.com

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
